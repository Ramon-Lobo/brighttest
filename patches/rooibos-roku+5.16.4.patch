+
+' [roku-test patch] Directly notify a promise's listeners WITHOUT relying on the promiseState field
+' observer. brs-node rejects observeFieldScoped registered by an anonymous function's name
+' ("$anon_N" → returns false), so the observer-based notification never fires headless and promise
+' chains (which back Rooibos @SGNode node tests) never settle. Calling this synchronously from
+' resolve/reject/on makes promises settle in every environment. On-device the (still-registered)
+' observer later fires but finds the storage already cleared, so it is a harmless no-op.
+sub rooibos_promises_internal_notifyPromise(originalPromise as object)
+    if not rooibos_promises_isComplete(originalPromise) then
+        return
+    end if
+    storageId = "__promises__" + originalPromise.id
+    promiseStorage = m[storageId]
+    if promiseStorage = invalid then
+        return ' no listeners registered yet, or already handled
+    end if
+    rooibos_promises_internal_unobserveFieldScoped(originalPromise, "promiseState")
+    ' Clear before processing; new listeners created in callbacks re-create their own storage.
+    m.delete(storageId)
+    promiseState = originalPromise.promiseState
+    promiseResult = originalPromise.promiseResult
+    for each listener in promiseStorage.thenListeners
+        rooibos_promises_internal_processPromiseListener(originalPromise, listener, promiseState = "resolved", promiseResult)
+    end for
+    for each listener in promiseStorage.catchListeners
+        rooibos_promises_internal_processPromiseListener(originalPromise, listener, promiseState = "rejected", promiseResult)
+    end for
+    for each listener in promiseStorage.finallyListeners
+        rooibos_promises_internal_processPromiseListener(originalPromise, listener, true)
+    end for
+    if m.doesExist(storageId) then
+        ' Listeners were added during the callbacks above — process them too.
+        rooibos_promises_internal_notifyPromise(originalPromise)
     end if
