    <field id="action" type="string" value="" />
    <field id="focusEnter" type="boolean" value="false" onChange="onFocusEnter" />
  </interface>
  <script type="text/brightscript" uri="HomePanel.brs" />
  <children>
    <Label id="homeTitle" text="Home" translation="[80, 60]" />
