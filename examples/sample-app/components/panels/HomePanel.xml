    <Button id="searchButton"   text="Search"   translation="[80, 150]"  minWidth="220" />
    <Button id="settingsButton" text="Settings" translation="[320, 150]" minWidth="220" />
    <!-- content tiles -->
    <Button id="tileNews"   text="News"   translation="[80, 320]"  minWidth="260" />
    <Button id="tileSports" text="Sports" translation="[380, 320]" minWidth="260" />
    <Button id="tileMovies" text="Movies" translation="[680, 320]" minWidth="260" />
  </children>
</component>
