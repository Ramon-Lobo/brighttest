{
  "name": "brighttest",
  "version": "0.3.0",
  "description": "Unified BrightScript test runner — write Rooibos specs once, run headless (default) or on-device with coverage.",
  "license": "MIT",
  "author": "Ramon Lobo",
  "homepage": "https://ramon-lobo.github.io/brighttest/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ramon-Lobo/brighttest.git"
  },
  "bugs": {
    "url": "https://github.com/Ramon-Lobo/brighttest/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "brighttest": "bin/cli.js"
  },
  "files": [
    "bin",
    "lib",
    "brs",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.mjs",
    "test:watch": "vitest",
    "skills:manifest": "node scripts/gen-skills-manifest.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@ramonlobo/brs-node": "^2.2.0",
    "@ramonlobo/rooibos-roku": "^5.16.4",
    "brighterscript": "^0.73.0"
  },
  "devDependencies": {
    "mermaid": "11.16.0",
    "vitepress": "1.6.4",
    "vitepress-plugin-mermaid": "2.0.17",
    "vitest": "^2.1.9"
  }
}
